{
  "name": "tiramisu-docs-monorepo",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build:core": "cd packages/core && bun run build",
    "build:kit": "cd packages/kit && bun run build",
    "build:playground": "cd playground && bun run build",
    "build": "bun run build:core && bun run build:kit && bun run build:playground",
    "test": "bun run --filter '*' test"
  },
  "dependencies": {
    "@timeleap/tiramisu": "^1.9.0"
  }
}
