{
  "name": "@tiramisu-docs/kit",
  "version": "0.1.0",
  "type": "module",
  "svelte": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./components/*": {
      "svelte": "./src/lib/components/*",
      "default": "./src/lib/components/*"
    },
    "./styles/*": {
      "default": "./src/lib/styles/*"
    },
    "./utils": {
      "types": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test"
  },
  "dependencies": {
    "@timeleap/tiramisu": "^1.6.0",
    "@tiramisu-docs/core": "workspace:*",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "minisearch": "^7.2.0",
    "katex": "^0.16.21",
    "mermaid": "^11.6.0",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@sveltejs/kit": "^2.0.0",
    "@types/node": "^20.12.11",
    "svelte": "^5.0.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.5",
    "vite": "^6.0.0"
  }
}
